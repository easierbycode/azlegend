{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check deno.json README.md main.ts utils.ts client.ts vite.config.ts routes && deno lint main.ts utils.ts client.ts vite.config.ts routes && deno check main.ts routes/**/*.tsx",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*",
    "node_modules"
  ],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@2.3.3",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@1.1.2",
    "preact": "npm:preact@10.29.1",
    "@preact/signals": "npm:@preact/signals@2.9.0",
    "vite": "npm:vite@7.1.3",
    "@types/babel__core": "npm:@types/babel__core@7.20.5"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "deploy": {
    "framework": "fresh"
  }
}
